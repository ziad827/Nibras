enum CompPlatform {
  codeforces
  leetcode
  atcoder
  codechef
  vjudge
  uhunt
  ctftime
  kaggle
  hackthebox
  tryhackme
  picoctf
  project_euler
  hackerone
  bugcrowd
  defcon
}

enum AccountVerificationStatus {
  pending
  verified
  failed
}

model Contest {
  id                String       @id @default(cuid())
  platform          CompPlatform
  platformContestId String
