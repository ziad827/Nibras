  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  topic     CpRoadmapTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model CpRoadmapTemplate {
  id        String         @id @default(cuid())
  topicId   String
  url       String
  sortOrder Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  topic     CpRoadmapTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
}

model CpRoadmapProblem {
  id             String                  @id @default(cuid())
  slug           String                  @unique
  title          String
  url            String
  sourcePlatform String                  @default("other")
  difficulty     Int                     @default(0)
  isStarred      Boolean                 @default(false)
  solveCount     Int?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  topicLinks     CpRoadmapTopicProblem[]
  progress       CpRoadmapProblemProgress[]
  notes          CpRoadmapProblemNote[]
  createdFromSuggestions CpRoadmapProblemSuggestion[]
}

model CpRoadmapTopicProblem {
  id        String           @id @default(cuid())
  topicId   String
  problemId String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  topic     CpRoadmapTopic   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  problem   CpRoadmapProblem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([topicId, problemId])
  @@index([topicId])
  @@index([problemId])
}

model CpRoadmapProblemSuggestion {
  id                String                    @id @default(cuid())
  userId            String
  topicId           String
  title             String
  url               String
  notes             String?
  difficulty        Int?
  status            CpRoadmapSuggestionStatus @default(pending)
  reviewerId        String?
  reviewedAt        DateTime?
  createdProblemId  String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  user              User                      @relation("CpRoadmapSuggestionAuthor", fields: [userId], references: [id], onDelete: Cascade)
  topic             CpRoadmapTopic            @relation(fields: [topicId], references: [id], onDelete: Cascade)
  reviewer          User?                     @relation("CpRoadmapSuggestionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  createdProblem    CpRoadmapProblem?         @relation(fields: [createdProblemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([topicId])
  @@index([status])
}

model CpRoadmapProblemProgress {
  id               String            @id @default(cuid())
  userId           String
  roadmapProblemId String
  solved           Boolean           @default(false)
  solvedAt         DateTime?
  userMarked       Boolean           @default(false)
  reviewAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem          CpRoadmapProblem? @relation(fields: [roadmapProblemId], references: [slug], onDelete: Cascade)

  @@unique([userId, roadmapProblemId])
  @@index([userId])
  @@index([roadmapProblemId])
}

model CpRoadmapProblemNote {
  id               String           @id @default(cuid())
  userId           String
  roadmapProblemId String
  note             String           @default("")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem          CpRoadmapProblem @relation(fields: [roadmapProblemId], references: [slug], onDelete: Cascade)

  @@unique([userId, roadmapProblemId])
  @@index([userId])
  @@index([roadmapProblemId])
}

model UserContestParticipation {
  id           String       @id @default(cuid())
  userId       String
  contestId    String
  platform     CompPlatform
  rank         Int?
  participants Int?
  ratingBefore Int?
  ratingAfter  Int?
  delta        Int?
  solvedCount  Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contest      Contest      @relation(fields: [contestId], references: [id], onDelete: Cascade)

  @@unique([userId, contestId])
  @@index([userId, platform])
  @@index([userId, createdAt])
}

model CachedRanking {
  id              String   @id @default(cuid())
  userId          String
  scope           String
  platform        String
  rank            Int
  rating          Int
  delta           Int      @default(0)
  contestsLast30d Int      @default(0)
  calculatedAt    DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope, platform])
  @@index([scope, platform, rank])
}

model CompSyncLog {
  id           String   @id @default(cuid())
  jobType      String
  platform     String?
  status       String
  itemCount    Int      @default(0)
  errorMessage String?
  startedAt    DateTime
  finishedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([jobType, createdAt])
}

// ── User social links (profile) ────────────────────────────────────────────

enum SocialPlatform {
  website
  linkedin
  x
  instagram
  youtube
  discord
}

model UserSocialLink {
  id        String         @id @default(cuid())
  userId    String
  platform  SocialPlatform
  value     String         @db.VarChar(512)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@index([userId])
}

// ── Daily Problem System ───────────────────────────────────────────────────

model DailyProblemConfig {
  id                String                  @id @default(cuid())
  userId            String                  @unique
  enabled           Boolean                 @default(true)
  difficultyPref    Int[]
  tagPrefs          String[]
  timezone          String                  @default("UTC")
  pausedUntil       DateTime?
  currentStreak     Int                     @default(0)
  longestStreak     Int                     @default(0)
  totalCompleted    Int                     @default(0)
  lastCompletedDate String?
  streakFreezes     Int                     @default(2)
  reminderEnabled   Boolean                 @default(false)
  reminderMinutesBefore Int                 @default(120)
  lastReminderDate  String?
  weeklyDigestEnabled Boolean               @default(false)
  lastWeeklyDigestWeek String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments       DailyProblemAssignment[]

  @@index([userId])
}

model DailyProblemAssignment {
  id           String              @id @default(cuid())
  userId       String
  problemId    String
  configId     String
  assignedDate String
  solved       Boolean             @default(false)
  solvedAt     DateTime?
  skipped      Boolean             @default(false)
  missedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem      Problem             @relation(fields: [problemId], references: [id], onDelete: Cascade)
  config       DailyProblemConfig  @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([userId, assignedDate])
  @@index([userId, solved])
  @@index([userId, assignedDate])
}

// ── Tutor Conversations ────────────────────────────────────────────────────

model TutorConversation {
  id        String         @id @default(cuid())
  userId    String
  title     String         @default("New conversation")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TutorMessage[]

  @@index([userId, updatedAt])
}

model TutorMessage {
  id                  String            @id @default(cuid())
  conversationId      String
  role                String
  content             String
  tags                String[]
  xaiReasoning        String?
  xaiConcepts         String[]
  xaiUnclear          String[]
  responseType        String?
  communityQuestionId String?
  matchScore          Float?
  feedbackRating      String?
  feedbackComment     String?
  createdAt           DateTime          @default(now())
  conversation        TutorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── Gamification & Reputation ───────────────────────────────────────────────

enum BadgeRarity {
  common
  rare
  epic
  legendary
}

enum BadgeCategory {
  onboarding
  projects
  community
  practice
  competitions
  rating
  meta
}

enum ReputationCategory {
  course
  community
  problem
  contest
  badge
}

model BadgeDefinition {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String        @default("")
  iconUrl     String?
  rarity      BadgeRarity   @default(common)
  category    BadgeCategory @default(onboarding)
  threshold   Int           @default(1)
  points      Int           @default(0)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userBadges  UserBadge[]

  @@index([category, sortOrder])
}

model UserBadge {
  id        String          @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId, earnedAt])
}

model UserGamificationMetrics {
  userId                    String   @id
  githubLinked              Boolean  @default(false)
  githubAppInstalled        Boolean  @default(false)
  courseEnrollments         Int      @default(0)
  passedSubmissions         Int      @default(0)
  totalSubmissions          Int      @default(0)
  failedSubmissions         Int      @default(0)
  teamMemberships           Int      @default(0)
  questions                 Int      @default(0)
  answers                   Int      @default(0)
  acceptedAnswers           Int      @default(0)
  questionUpvotesReceived   Int      @default(0)
  communityVotes            Int      @default(0)
  threads                   Int      @default(0)
  threadPosts               Int      @default(0)
  solvedProblems            Int      @default(0)
  problemBookmarks          Int      @default(0)
  contestParticipations     Int      @default(0)
  contestBookmarks          Int      @default(0)
  assignmentSubmissions     Int      @default(0)
  videosWatched             Int      @default(0)
  earnedBadges              Int      @default(0)
  dailyStreakCurrent        Int      @default(0)
  dailyStreakLongest        Int      @default(0)
  dailyProblemsCompleted    Int      @default(0)
  codeforcesMaxRating       Int      @default(0)
  leetcodeMaxRating         Int      @default(0)
  plansSubmittedForAdvisor  Int      @default(0)
  programSheetsGenerated    Int      @default(0)
  cpRoadmapSolvedCount      Int      @default(0)
  cpRoadmapTopicsComplete   Int      @default(0)
  cpRoadmapPercent          Int      @default(0)
  cpRoadmapCategoriesComplete Int    @default(0)
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReputationEvent {
  id        String             @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  source    String
  category  ReputationCategory @default(course)
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source])
  @@index([userId, createdAt])
  @@index([userId, category])
}

model UserAiCredential {
  id              String   @id @default(cuid())
  userId          String   @unique
  provider        String   @default("openai")
  baseUrl         String?
  encryptedApiKey String
  model           String   @default("gpt-4o-mini")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
