  updatedAt        DateTime       @updatedAt
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets           ProjectAsset[]
  submissions      SubmissionAttempt[]

  @@unique([projectId, version])
}

model ProjectAsset {
  id                String          @id @default(cuid())
  projectReleaseId  String
  visibility        AssetVisibility
  kind              String
  storageKey        String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  projectRelease    ProjectRelease  @relation(fields: [projectReleaseId], references: [id], onDelete: Cascade)
}

model UserProjectRepo {
  id              String         @id @default(cuid())
  userId          String
  projectId       String
  owner           String
  name            String
  githubRepoId    String?
  cloneUrl        String?
  defaultBranch   String
  visibility      RepoVisibility @default(private)
  installStatus   String         @default("provisioned")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions     SubmissionAttempt[]

  @@unique([userId, projectId])
}

model SubmissionAttempt {
  id               String            @id @default(cuid())
  userId           String
  submittedByUserId String?
  projectId        String
  projectReleaseId String
  userProjectRepoId String?
  teamId           String?
  teamProjectRepoId String?
  milestoneId      String?
  commitSha        String
  repoUrl          String
  branch           String
  status           SubmissionStatus  @default(queued)
  summary          String
  submissionType   TrackingSubmissionType @default(github)
  submissionValue  String?
  notes            String?
  submittedAt      DateTime?
  localTestExitCode Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedByUser  User?             @relation("SubmissionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Restrict)
  projectRelease   ProjectRelease    @relation(fields: [projectReleaseId], references: [id], onDelete: Restrict)
  userProjectRepo  UserProjectRepo?  @relation(fields: [userProjectRepoId], references: [id], onDelete: Cascade)
  team             Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamProjectRepo  TeamProjectRepo?  @relation(fields: [teamProjectRepoId], references: [id], onDelete: SetNull)
  milestone        Milestone?        @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  reviews           Review[]
  githubDeliveries  GithubDelivery[]
  auditLogs         AuditLog[]
  verificationRuns  VerificationRun[]
  verificationJob   VerificationJob?

  @@unique([userId, projectId, commitSha])
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([milestoneId])
  @@index([teamId])
}

model Milestone {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String             @default("")
  slug        String?
  order       Int
  dueAt       DateTime?
  isFinal     Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions SubmissionAttempt[]
  auditLogs   AuditLog[]

  @@unique([projectId, order])
  @@unique([projectId, slug])
  @@index([projectId])
}

model Review {
  id                   String            @id @default(cuid())
  submissionAttemptId  String
  reviewerUserId       String
  status               ReviewStatus
  score                Float?
  feedback             String            @default("")
  rubricJson           Json?
  reviewedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  // AI grading fields (nullable — populated by worker when AI config is present)
  aiConfidence         Float?
  aiNeedsReview        Boolean?
  aiReasoningSummary   String?
  aiCriterionScores    Json?
  aiEvidenceQuotes     Json?
  aiModel              String?
  aiGradedAt           DateTime?
  submissionAttempt    SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)
  reviewer             User              @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@index([submissionAttemptId])
}

model GithubDelivery {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  repoUrl             String
  eventType           String
  deliveryId          String
  ref                 String
  commitSha           String
  payloadJson         Json?
  receivedAt          DateTime          @default(now())
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([deliveryId])
}

model VerificationRun {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  attempt             Int               @default(0)
  status              SubmissionStatus  @default(queued)
  log                 String
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([submissionAttemptId, attempt])
}

model VerificationJob {
  id                  String            @id @default(cuid())
  submissionAttemptId String            @unique
  traceId             String            @default(cuid())
  status              SubmissionStatus  @default(queued)
  attempt             Int               @default(0)
  maxAttempts         Int               @default(3)
  claimedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@index([status, claimedAt, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
