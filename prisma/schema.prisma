generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum SubmissionStatus {
  queued
  running
  passed
  failed
  needs_review
  cancelled
}

enum SystemRole {
  user
  admin
}

enum CourseRole {
  student
  instructor
  ta
}

enum CourseEnrollmentRequestStatus {
  pending
  approved
  rejected
}

enum VideoProvider {
  youtube
  bilibili
  mp4
  url
}

enum AssignmentSubmissionStatus {
  draft
  submitted
  graded
}

enum CourseAssignmentType {
  text
  mcq
  quiz
}

enum ProjectStatus {
  draft
  published
  archived
}

enum DeliveryMode {
  individual
  team
}

enum ProjectTemplateStatus {
  draft
  active
}

enum ProjectTemplateDifficulty {
  beginner
  intermediate
  advanced
}

enum ProjectInterestStatus {
  pending
  approved
  rejected
}

enum TeamFormationStatus {
  not_started
  application_open
  team_review
  teams_locked
}

enum ProjectRoleApplicationStatus {
  submitted
  withdrawn
}

enum TeamStatus {
  suggested
  locked
}

enum TrackingSubmissionType {
  github
  link
  text
}

enum ReviewStatus {
  pending
  approved
  changes_requested
  graded
}

enum ProgramStatus {
  draft
  published
  archived
}

enum RequirementGroupCategory {
  foundation
  core
  depth
  elective
  capstone
  policy
}

enum RequirementRuleType {
  required
  choose_n
  elective_pool
  track_gate
}

enum StudentProgramStatus {
  enrolled
  track_selected
  submitted_for_advisor
  advisor_approved
  department_approved
}

enum PlannedCourseSourceType {
  standard
  transfer
  petition
  manual
}

enum StudentRequirementDecisionStatus {
  pending
  satisfied
  waived
  petition_pending
}

enum RequirementDecisionSourceType {
  planned_course
  transfer_credit
  petition
  waiver
}

enum PetitionType {
  transfer_credit
  substitution
  waiver
}

enum PetitionStatus {
  pending_advisor
  pending_department
  approved
  rejected
}

enum ApprovalStage {
  advisor
  department
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum AcademicTerm {
  fall
  spring
  summer
  away
}

enum RepoVisibility {
  private
  public
}

enum AssetVisibility {
  public
  private
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  emailVerified     Boolean            @default(false)
  image             String?
  /// User-chosen display name shown in the UI (falls back to username when unset).
  displayName       String?
  /// Short public bio shown on user profile pages.
  bio               String?            @db.VarChar(500)
  /// Optional inbox for transactional email (e.g. Gmail). When set, used instead of account email.
  notificationEmail String?
  githubLinked      Boolean            @default(false)
  githubAppInstalled Boolean           @default(false)
  systemRole        SystemRole         @default(user)
  yearLevel         Int                @default(1)
  bannedAt          DateTime?
  banReason         String?
  banExpiresAt      DateTime?
  /// CLI onboarding checklist completion keyed by step id (e.g. step-03).
  onboardingProgress Json              @default("{}")
  lastReputationSyncAt DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  githubAccount     GithubAccount?
  courseMemberships CourseMembership[]
  courseEnrollmentRequests CourseEnrollmentRequest[]
  reviewedCourseEnrollmentRequests CourseEnrollmentRequest[] @relation("EnrollmentRequestReviewer")
  deviceCodes       DeviceCode[]
  cliSessions       CliSession[]
  webSessions       WebSession[]
  userProjectRepos  UserProjectRepo[]
  submissionAttempts SubmissionAttempt[]
  submittedAttempts SubmissionAttempt[] @relation("SubmissionSubmittedBy")
  auditLogs         AuditLog[]
  reviews           Review[]
  notifications     Notification[]
  notificationPreferences NotificationPreference[]
  projectRoleApplications ProjectRoleApplication[]
  projectInterests  ProjectInterest[]
  teamMembers       TeamMember[]
  createdTeamFormationRuns TeamFormationRun[]
  studentPrograms   StudentProgram[]
  submittedPetitions Petition[]        @relation("ProgramPetitionSubmitter")
  reviewedPetitions Petition[]         @relation("ProgramPetitionReviewer")
  reviewedProgramApprovals ProgramApproval[]
  communityQuestions       CommunityQuestion[] @relation("CommunityQuestionAuthor")
  communityAnswers         CommunityAnswer[]   @relation("CommunityAnswerAuthor")
  communityVotes           CommunityVote[]     @relation("CommunityVoteUser")
  communityThreads         CommunityThread[]   @relation("CommunityThreadAuthor")
  communityPosts           CommunityPost[]     @relation("CommunityPostAuthor")
  courseVideoComments      CourseVideoComment[] @relation("CourseVideoCommentAuthor")
  communityReports         CommunityReport[]   @relation("CommunityReportReporter")
  communityReportsReviewed CommunityReport[]   @relation("CommunityReportReviewer")
  communityQuestionBookmarks CommunityQuestionBookmark[]
  contestBookmarks         ContestBookmark[]
  contestReminders         ContestReminder[]
  problemBookmarks         ProblemBookmark[]
  problemProgress          UserProblemProgress[]
  linkedAccounts           LinkedAccount[]
  nibras75Workspace        Nibras75Workspace?
  nibras75Config           Nibras75Config?
  nibras75ProblemNotes     Nibras75ProblemNote[]
  contestParticipations    UserContestParticipation[]
  cachedRankings           CachedRanking[]
  tutorConversations       TutorConversation[]
  userBadges               UserBadge[]
  gamificationMetrics      UserGamificationMetrics?
  reputationEvents         ReputationEvent[]
  videoProgress            VideoProgress[]
  assignmentSubmissions    AssignmentSubmission[]
  aiInteractions           AIInteraction[]
  aiCredential             UserAiCredential?
  authSessions             AuthSession[]
  authAccounts             AuthAccount[]
  dailyProblemConfig       DailyProblemConfig?
  dailyProblemAssignments  DailyProblemAssignment[]
  cpRoadmapProgress        CpRoadmapProblemProgress[]
  cpRoadmapProblemNotes    CpRoadmapProblemNote[]
  cpRoadmapSuggestions     CpRoadmapProblemSuggestion[] @relation("CpRoadmapSuggestionAuthor")
  cpRoadmapSuggestionsReviewed CpRoadmapProblemSuggestion[] @relation("CpRoadmapSuggestionReviewer")
  socialLinks              UserSocialLink[]

  @@index([systemRole])
  @@index([yearLevel])
}

/// Better Auth session store (separate from WebSession / CliSession).
model AuthSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_session")
}

/// Better Auth linked OAuth / credential accounts.
model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_account")
}

/// Better Auth verification tokens (magic link, etc.).
model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("auth_verification")
}

model Course {
  id               String             @id @default(cuid())
  slug             String             @unique
  title            String
  termLabel        String
  courseCode       String
  description      String             @default("")
  thumbnailUrl     String?
  syllabusJson     Json?
  sequentialVideos Boolean            @default(false)
  isPublic         Boolean            @default(false)
  isActive         Boolean            @default(true)
  deletedAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  reputationWeights Json?
  memberships      CourseMembership[]
  projects         Project[]
  projectTemplates ProjectTemplate[]
  invites          CourseInvite[]
  auditLogs        AuditLog[]
  communityThreads CommunityThread[]
  sections         CourseSection[]
  assignments      CourseAssignment[]
  enrollmentRequests CourseEnrollmentRequest[]
  linkedCatalogCourse CatalogCourse?
}

model CourseInvite {
  id        String      @id @default(cuid())
  courseId  String
  code      String      @unique
  role      CourseRole  @default(student)
  maxUses   Int         @default(0)
  useCount  Int         @default(0)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseMembership {
  id         String     @id @default(cuid())
  courseId   String
  userId     String
  role       CourseRole
  level      Int        @default(1)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
}

model CourseEnrollmentRequest {
  id         String                        @id @default(cuid())
  courseId   String
  userId     String
  status     CourseEnrollmentRequestStatus @default(pending)
  message    String?                       @db.VarChar(500)
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime                      @default(now())
  updatedAt  DateTime                      @updatedAt
  course     Course                        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer   User?                         @relation("EnrollmentRequestReviewer", fields: [reviewedBy], references: [id])

  @@unique([courseId, userId])
  @@index([courseId, status])
}

model CourseSection {
  id          String        @id @default(cuid())
  courseId    String
  title       String
  description String?
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  videos      CourseVideo[]

  @@index([courseId, sortOrder])
}

model CourseVideo {
  id                String         @id @default(cuid())
  sectionId         String
  title             String
  description       String?
  provider          VideoProvider
  externalId        String?
  embedUrl          String?
  durationSeconds   Int?
  sortOrder         Int            @default(0)
  requiresVideoId   String?
  linkedProjectId   String?
  linkedMilestoneId String?
  resourcesJson     Json           @default("[]")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  section           CourseSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  requiresVideo     CourseVideo?   @relation("VideoPrerequisite", fields: [requiresVideoId], references: [id], onDelete: SetNull)
  dependentVideos   CourseVideo[]  @relation("VideoPrerequisite")
  linkedProject     Project?       @relation(fields: [linkedProjectId], references: [id], onDelete: SetNull)
  progress          VideoProgress[]
  comments          CourseVideoComment[]

  @@index([sectionId, sortOrder])
}

model CourseVideoComment {
  id               String                    @id @default(cuid())
  videoId          String
  authorId         String
  body             String
  moderationStatus CommunityModerationStatus @default(visible)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  video            CourseVideo               @relation(fields: [videoId], references: [id], onDelete: Cascade)
  author           User                      @relation("CourseVideoCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([videoId, createdAt])
  @@index([authorId])
  @@index([moderationStatus])
}

model CourseAssignment {
  id              String                 @id @default(cuid())
  courseId        String
  title           String
  description     String                 @default("")
  content         String                 @default("")
  assignmentType  CourseAssignmentType   @default(text)
  configJson      Json                   @default("{}")
  dueAt           DateTime?
  pointsPossible  Int                    @default(100)
  sortOrder       Int                    @default(0)
  published       Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  course          Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions     AssignmentSubmission[]

  @@index([courseId, sortOrder])
}

model AssignmentSubmission {
  id            String                     @id @default(cuid())
  assignmentId  String
  userId        String
  content       String                     @default("")
  answersJson   Json                       @default("{}")
  resourcesJson Json                       @default("[]")
  status        AssignmentSubmissionStatus @default(draft)
  score         Float?
  feedback      String?
  submittedAt   DateTime?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  assignment    CourseAssignment           @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([userId])
}

model VideoProgress {
  id              String      @id @default(cuid())
  userId          String
  videoId         String
  watched         Boolean     @default(false)
  watchedProgress Float       @default(0)
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  video           CourseVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([userId])
}

model Program {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  title                String
  code                 String
  academicYear         String
  totalUnitRequirement Int
  status               ProgramStatus     @default(draft)
  activeVersionId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  versions             ProgramVersion[]
  catalogCourses       CatalogCourse[]
}

model ProgramVersion {
  id                     String            @id @default(cuid())
  programId              String
  versionLabel           String
  effectiveFrom          DateTime?
  effectiveTo            DateTime?
  isActive               Boolean           @default(false)
  policyText             String            @default("")
  trackSelectionMinYear  Int               @default(2)
  durationYears          Int               @default(4)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  program                Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  tracks                 Track[]
  requirementGroups      RequirementGroup[]
  studentPrograms        StudentProgram[]
  sheetSnapshots         ProgramSheetSnapshot[]

  @@index([programId, isActive])
}

model Track {
  id                  String             @id @default(cuid())
  programVersionId    String
  slug                String
  title               String
  description         String             @default("")
  selectionYearStart  Int                @default(2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  programVersion      ProgramVersion     @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  requirementGroups   RequirementGroup[]
  selectedByStudents  StudentProgram[]

  @@unique([programVersionId, slug])
}

model CatalogCourse {
  id                     String               @id @default(cuid())
  programId              String
  subjectCode            String
  catalogNumber          String
  title                  String
  defaultUnits           Int
  department             String
  plannerCode            String?
  trackingCourseId       String?              @unique
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  program                Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  trackingCourse         Course?              @relation(fields: [trackingCourseId], references: [id], onDelete: SetNull)
  requirementCourses     RequirementCourse[]
  studentPlannedCourses  StudentPlannedCourse[]
  originalPetitionLinks  PetitionCourseLink[] @relation("OriginalPetitionCourse")
  substitutePetitionLinks PetitionCourseLink[] @relation("SubstitutePetitionCourse")
  prerequisites          CatalogCoursePrerequisite[] @relation("CoursePrerequisites")
  prerequisiteFor        CatalogCoursePrerequisite[] @relation("PrerequisiteFor")

  @@unique([programId, subjectCode, catalogNumber])
  @@index([programId, plannerCode])
}

model CatalogCoursePrerequisite {
  id                   String        @id @default(cuid())
  catalogCourseId      String
  prerequisiteCourseId String
  catalogCourse        CatalogCourse @relation("CoursePrerequisites", fields: [catalogCourseId], references: [id], onDelete: Cascade)
  prerequisiteCourse   CatalogCourse @relation("PrerequisiteFor", fields: [prerequisiteCourseId], references: [id], onDelete: Cascade)

  @@unique([catalogCourseId, prerequisiteCourseId])
  @@index([catalogCourseId])
  @@index([prerequisiteCourseId])
}

model RequirementGroup {
  id                String                @id @default(cuid())
  programVersionId  String
  trackId           String?
  title             String
  category          RequirementGroupCategory
  minUnits          Int                   @default(0)
  minCourses        Int                   @default(0)
  notes             String                @default("")
  sortOrder         Int                   @default(0)
  noDoubleCount     Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  programVersion    ProgramVersion        @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  track             Track?                @relation(fields: [trackId], references: [id], onDelete: SetNull)
  rules             RequirementRule[]
  decisions         StudentRequirementDecision[]
  petitions         Petition[]

  @@index([programVersionId, trackId, sortOrder])
}

model RequirementRule {
  id                  String             @id @default(cuid())
  requirementGroupId  String
  ruleType            RequirementRuleType
  pickCount           Int?
  note                String             @default("")
  sortOrder           Int                @default(0)
  requirementGroup    RequirementGroup   @relation(fields: [requirementGroupId], references: [id], onDelete: Cascade)
  courses             RequirementCourse[]

  @@index([requirementGroupId, sortOrder])
}

model RequirementCourse {
  id                 String           @id @default(cuid())
  requirementRuleId  String
  catalogCourseId    String
  requirementRule    RequirementRule  @relation(fields: [requirementRuleId], references: [id], onDelete: Cascade)
  catalogCourse      CatalogCourse    @relation(fields: [catalogCourseId], references: [id], onDelete: Cascade)

  @@unique([requirementRuleId, catalogCourseId])
}

model StudentProgram {
  id              String                       @id @default(cuid())
  userId          String
  programVersionId String
  selectedTrackId String?
  suid            String?
  expectedGraduationQuarter String?
  status          StudentProgramStatus        @default(enrolled)
  isLocked        Boolean                     @default(false)
  submittedForAdvisorAt DateTime?
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  programVersion  ProgramVersion              @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  selectedTrack   Track?                      @relation(fields: [selectedTrackId], references: [id], onDelete: SetNull)
  plannedCourses  StudentPlannedCourse[]
  decisions       StudentRequirementDecision[]
  petitions       Petition[]
  approvals       ProgramApproval[]
  sheetSnapshots  ProgramSheetSnapshot[]

  @@index([userId])
  @@index([userId, programVersionId])
}

model StudentPlannedCourse {
  id               String                  @id @default(cuid())
  studentProgramId String
  catalogCourseId  String
  plannedYear      Int
  plannedTerm      AcademicTerm
  sourceType       PlannedCourseSourceType @default(standard)
  note             String?
  expectedGrade    String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  studentProgram   StudentProgram          @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  catalogCourse    CatalogCourse           @relation(fields: [catalogCourseId], references: [id], onDelete: Cascade)

  @@unique([studentProgramId, catalogCourseId, plannedYear, plannedTerm])
  @@index([studentProgramId, plannedYear, plannedTerm])
}

model StudentRequirementDecision {
  id                String                          @id @default(cuid())
  studentProgramId  String
  requirementGroupId String
  status            StudentRequirementDecisionStatus
  sourceType        RequirementDecisionSourceType?
  notes             String?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  studentProgram    StudentProgram                  @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  requirementGroup  RequirementGroup                @relation(fields: [requirementGroupId], references: [id], onDelete: Cascade)

  @@unique([studentProgramId, requirementGroupId])
}

model Petition {
  id                     String          @id @default(cuid())
  studentProgramId       String
  type                   PetitionType
  status                 PetitionStatus  @default(pending_advisor)
  justification          String
  attachmentUrl          String?
  targetRequirementGroupId String?
  submittedByUserId      String
  reviewerUserId         String?
  reviewerNotes          String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  studentProgram         StudentProgram  @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  targetRequirementGroup RequirementGroup? @relation(fields: [targetRequirementGroupId], references: [id], onDelete: SetNull)
  submittedByUser        User            @relation("ProgramPetitionSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  reviewerUser           User?           @relation("ProgramPetitionReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  courseLinks            PetitionCourseLink[]

  @@index([studentProgramId, status])
}

model PetitionCourseLink {
  id                       String        @id @default(cuid())
  petitionId               String
  originalCatalogCourseId  String?
  substituteCatalogCourseId String?
  petition                 Petition      @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  originalCatalogCourse    CatalogCourse? @relation("OriginalPetitionCourse", fields: [originalCatalogCourseId], references: [id], onDelete: SetNull)
  substituteCatalogCourse  CatalogCourse? @relation("SubstitutePetitionCourse", fields: [substituteCatalogCourseId], references: [id], onDelete: SetNull)
}

model ProgramApproval {
  id               String         @id @default(cuid())
  studentProgramId String
  stage            ApprovalStage
  status           ApprovalStatus @default(pending)
  reviewerUserId   String?
  notes            String?
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  reviewerUser     User?          @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@unique([studentProgramId, stage])
}

model ProgramSheetSnapshot {
  id               String         @id @default(cuid())
  studentProgramId String
  versionId        String
  renderedPayload  Json
  generatedAt      DateTime       @default(now())
  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  version          ProgramVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([studentProgramId, generatedAt])
}

model GithubAccount {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  githubUserId              String   @unique
  login                     String
  installationId            String?
  userAccessToken           String?
  userRefreshToken          String?
  userAccessTokenExpiresAt  DateTime?
  userRefreshTokenExpiresAt DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceCode {
  id              String   @id @default(cuid())
  deviceCode      String   @unique
  userCode        String   @unique
  expiresAt       DateTime
  intervalSeconds Int
  status          String
  userId          String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CliSession {
  id            String    @id @default(cuid())
  accessToken   String    @unique
  refreshToken  String    @unique
  userId        String
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subject {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id               String            @id @default(cuid())
  subjectId        String
  courseId         String?
  templateId       String?
  slug             String            @unique
  name             String
  defaultBranch    String            @default("main")
  description      String            @default("")
  status           ProjectStatus     @default(draft)
  level            Int               @default(1)
  deletedAt        DateTime?
  deliveryMode     DeliveryMode      @default(individual)
  applicationOpenAt DateTime?
  applicationCloseAt DateTime?
  teamLockAt       DateTime?
  teamFormationStatus TeamFormationStatus @default(not_started)
  rubricJson       Json?
  resourcesJson    Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  course           Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  template         ProjectTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  releases         ProjectRelease[]
  milestones       Milestone[]
  userProjectRepos UserProjectRepo[]
  submissions      SubmissionAttempt[]
  roleApplications ProjectRoleApplication[]
  teamFormationRuns TeamFormationRun[]
  teams            Team[]
  linkedVideos     CourseVideo[]
  auditLogs        AuditLog[]
  interests        ProjectInterest[]

  @@index([courseId, status])
}

model ProjectTemplate {
  id          String               @id @default(cuid())
