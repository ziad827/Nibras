meta {
  name: Create Section
  type: http
  seq: 2
}

post {
  url: {{trackingBaseUrl}}/v1/tracking/courses/{{courseId}}/sections
  body: json
  auth: bearer
}

auth:bearer {
  token: {{trackingToken}}
}

body:json {
  {
    "title": "Week 1 — Introduction",
    "description": "Getting started with the course",
    "sortOrder": 0
  }
}

script:post-response {
  if (res.status === 200 && res.body.id) {
    bru.setVar("sectionId", res.body.id);
    bru.setEnvVar("sectionId", res.body.id);
  }
}
