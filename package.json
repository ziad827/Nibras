{
  "name": "nibras",
  "version": "0.2.0",
  "description": "Nibras Educational Platform — full-stack collaborative learning, competitive programming, and project-based assessment.",
  "author": "NibrasPlatform",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NibrasPlatform/Nibras.git"
  },
  "bin": {
    "nibras": "bin/nibras.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "nest build && tsc-alias",
    "build:platform": "npm run db:generate && npm run build -w @nibras/contracts && npm run build -w @nibras/daily-problem && npm run build -w @nibras/core && npm run build -w @nibras/github && npm run build -w @nibras/grading && npm run build -w @nibras/api && npm run build -w @nibras/proxy && npm run build -w @nibras/cli && npm run build -w @nibras/worker",
    "build:all": "npm run build:platform && npm run build",
    "build:cli:package": "npm --prefix packages/contracts run build && npm --prefix packages/core run build && npm --prefix apps/cli run build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:platform": "npm run build:platform && node --test test-monorepo/*.js",
    "dev:session": "node -r tsconfig-paths/register -r ts-node/register scripts/local-dev-session.ts",
    "dev:student": "node -r tsconfig-paths/register -r ts-node/register scripts/local-dev-student.ts",
    "seed:tags": "node -r tsconfig-paths/register -r ts-node/register scripts/seed-tags.ts",
    "smoke:local": "bash scripts/full-system-smoke.sh",
    "smoke:gateway": "bash scripts/gateway-smoke.sh",
    "smoke:api-prod": "bash scripts/api-smoke-prod.sh",
    "smoke:socket": "node scripts/socket-contest-listen.mjs",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy",
    "db:local:reset": "docker compose down -v && docker compose up -d postgres mongodb redis && until docker compose exec -T postgres pg_isready -U nibras -d nibras; do sleep 1; done",
    "db:local:migrate": "npm run db:deploy",
    "api:dev": "PORT=4848 node -r dotenv/config apps/api/dist/server.js",
    "worker:dev": "node -r dotenv/config apps/worker/dist/worker.js",
    "proxy:dev": "node -r dotenv/config apps/proxy/dist/server.js",
    "tutor:dev": "cd apps/tutor && TUTOR_PORT=5000 python3 app.py",
    "dev:bootstrap": "node scripts/monorepo/dev-bootstrap.js",
    "dev:watch": "concurrently -k --names contracts,daily-problem,core,github,grading,api,proxy,worker \"npm run watch -w @nibras/contracts\" \"npm run watch -w @nibras/daily-problem\" \"npm run watch -w @nibras/core\" \"npm run watch -w @nibras/github\" \"npm run watch -w @nibras/grading\" \"npm run watch -w @nibras/api\" \"npm run watch -w @nibras/proxy\" \"npm run watch -w @nibras/worker\"",
    "dev:services": "concurrently -k --names api,worker \"nodemon --delay 5 --watch apps/api/dist --watch packages/contracts/dist --watch packages/core/dist --watch packages/github/dist --watch packages/grading/dist --ext js,json --signal SIGTERM --exec \\\"npm run api:dev\\\"\" \"nodemon --delay 5 --watch apps/worker/dist --watch packages/contracts/dist --watch packages/core/dist --watch packages/github/dist --watch packages/grading/dist --ext js,json --signal SIGTERM --exec \\\"npm run worker:dev\\\"\"",
    "dev:platform": "npm run dev:bootstrap && concurrently -k \"npm run dev:watch\" \"npm run dev:services\"",
    "dev:full": "concurrently -k --names nest,platform,proxy \"npm run start:dev\" \"npm run dev:platform\" \"npm run proxy:dev\"",
    "seed:stanford": "npx tsx prisma/seed-stanford.ts",
    "seed:stanford-projects": "npx tsx prisma/seed-stanford-projects.ts",
    "seed:open-curricula": "npx tsx prisma/seed-open-curricula.ts",
    "seed:open-curricula-projects": "npx tsx prisma/seed-open-curricula-projects.ts",
    "seed:year1": "npx tsx prisma/seed-year1.ts",
    "seed:year2": "npx tsx prisma/seed-year2.ts",
    "seed:year3": "npx tsx prisma/seed-year3.ts",
    "seed:year4": "npx tsx prisma/seed-year4.ts",
    "seed:community": "npx tsx prisma/seed-community.ts",
    "seed:cp-roadmap": "npx tsx prisma/seed-cp-roadmap.ts",
    "seed:screenshot": "npx tsx prisma/seed-screenshot.ts",
    "judge0:dev": "docker compose -f docker-compose.judge0.yml up -d",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "@prisma/client": "^6.5.0",
    "cache-manager": "^7.2.8",
    "cacheable": "^2.3.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "commander": "^12.1.0",
    "ioredis": "^5.11.0",
    "joi": "^18.2.1",
    "keyv": "^5.6.0",
    "mongoose": "^9.6.3",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/passport-github2": "^1.2.9",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.4.2",
    "prisma": "^6.5.0",
    "redis-memory-server": "^0.16.1",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@modules/(.*)$": "<rootDir>/modules/$1",
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@database/(.*)$": "<rootDir>/database/$1"
    }
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
