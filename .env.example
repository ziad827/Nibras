# =============================================================================
# Nibras Backend — environment template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# All variables are validated at boot via Joi (src/config/validation.ts).
# =============================================================================

# ---- App ----
NODE_ENV=development
PORT=3000
# Path (no leading slash) where Swagger UI will be mounted.
SWAGGER_PATH=api/docs

# ---- MongoDB ----
# Full connection string. For docker-compose use `mongodb://mongodb:27017/nibras`.
MONGO_URI=mongodb://localhost:27017/nibras
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
# Retry policy used by @nestjs/mongoose when the initial connection fails.
MONGO_RETRY_ATTEMPTS=5
MONGO_RETRY_DELAY_MS=3000

# ---- Redis (cache + future real-time features) ----
# For docker-compose use `redis` as the host.
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank if Redis has no auth (local dev default).
REDIS_PASSWORD=
REDIS_TTL_SECONDS=60
