# =============================================================================
# Nibras Full Service — environment template
# Copy to `.env` and fill in real values. `.env` is git-ignored.
# =============================================================================

# =============================================================================
# NestJS backend (auth, community, competitions, courses) — port 3000
# Validated at boot via Joi (src/config/validation.ts).
# =============================================================================

NODE_ENV=development
PORT=3000
SWAGGER_PATH=api/docs

MONGO_URI=mongodb://localhost:27017/nibras
MONGO_MAX_POOL_SIZE=10
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_RETRY_ATTEMPTS=5
MONGO_RETRY_DELAY_MS=3000

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_SECONDS=60

AUTH_SECRET=nibras-dev-auth-secret-local
WEB_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
RESEND_API_KEY=
# Optional sender for signup/reset OTP emails (admin auth on Fastify). When unset, OTP codes are logged to the API console in dev.
NIBRAS_EMAIL_FROM=Nibras <noreply@nibras.dev>
NIBRAS_EMAIL_FROM=Nibras <noreply@nibras.dev>
SESSION_TTL_DAYS=30
MAGIC_LINK_TTL_SECONDS=300

COMPETITIONS_SYNC_ENABLED=false
# Keep false in production: worker BullMQ owns contest-sync. NestJS scheduler is not registered.
CONTEST_SYNC_CRON=*/15 * * * *
PROBLEM_SYNC_CRON=0 */6 * * *
ACCOUNT_STATS_SYNC_CRON=0 */6 * * *
RANKING_CALC_CRON=*/30 * * * *
CONTEST_REMINDER_CRON=* * * * *
POST_CONTEST_CRON=*/10 * * * *

AI_SERVICE_URL=
AI_TIMEOUT=300000

# =============================================================================
# Fastify platform API (projects, CLI, tracking, programs) — port 4848
# api:dev sets PORT=4848 at runtime; do not change NestJS PORT above.
# =============================================================================

DATABASE_URL=postgresql://nibras:nibras@127.0.0.1:5432/nibras?schema=public
DIRECT_DATABASE_URL=postgresql://nibras:nibras@127.0.0.1:5432/nibras?schema=public

REDIS_URL=
NIBRAS_DB_QUERY_LOG=
NIBRAS_CACHE_LOG=
NIBRAS_RUNTIME_CURRICULUM_SEED=
NIBRAS_AUTO_ENROLL_PUBLIC=
NIBRAS_DEMO_SHOWCASE_SEED=
NIBRAS_DEMO_PASSWORD=local123
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_MS=2000
WORKER_HEALTH_PORT=9090
WORKER_SANDBOX_MODE=ulimit
WORKER_MAX_CPU_SECONDS=60
WORKER_MAX_MEM_MB=512

HOST=127.0.0.1
NIBRAS_API_STORE=tmp/nibras-api-store.json
NIBRAS_API_BASE_URL=http://127.0.0.1:8080
NIBRAS_WEB_BASE_URL=http://127.0.0.1:8080

CHATBOT_V1_URL=http://127.0.0.1:5000
NEXT_PUBLIC_NIBRAS_RECOMMENDATION_API_URL=https://recommendationmodel-production-0f8e.up.railway.app/api

JUDGE0_API_URL=http://127.0.0.1:2358
JUDGE0_AUTH_TOKEN=nibras-judge0-dev-token
JUDGE0_CPU_TIME_LIMIT=5
JUDGE0_MEMORY_LIMIT=128000

NIBRAS_WEB_CORS_ORIGINS=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=
NIBRAS_75_TEMPLATE_OWNER=
NIBRAS_75_TEMPLATE_REPO=nibras-75

NIBRAS_ENCRYPTION_KEY=
RESEND_NEWSLETTER_AUDIENCE_ID=
CONNECTION_TIMEOUT_MS=10000
REQUEST_TIMEOUT_MS=30000
RATE_LIMIT_MAX=100
BODY_LIMIT_BYTES=524288
LOG_LEVEL=info
NIBRAS_SWAGGER_ENABLED=false
NIBRAS_METRICS_TOKEN=
SENTRY_DSN=

NIBRAS_AI_API_KEY=
NIBRAS_AI_MODEL=gpt-4o-mini
NIBRAS_AI_BASE_URL=https://api.openai.com/v1
NIBRAS_AI_TIMEOUT_MS=30000
NIBRAS_AI_MAX_RETRIES=2
NIBRAS_AI_MIN_CONFIDENCE=0.8

# =============================================================================
# Unified gateway (static Frontend + dual API routing) — port 8080
# =============================================================================

NIBRAS_GATEWAY_HOST=127.0.0.1
NIBRAS_GATEWAY_PORT=8080
NIBRAS_PROXY_HOST=127.0.0.1
NIBRAS_PROXY_PORT=8080
NIBRAS_NESTJS_ORIGIN=http://127.0.0.1:3000
NIBRAS_FASTIFY_ORIGIN=http://127.0.0.1:4848
NIBRAS_LOCAL_API_ORIGIN=http://127.0.0.1:4848
NIBRAS_STATIC_ROOT=Frontend/client

# AI tutor (Flask) — port 5000
NIBRAS_TUTOR_ORIGIN=http://127.0.0.1:5000
TUTOR_BOT_USER_ID=
NIBRAS_INTERNAL_API_TOKEN=

# Production compose: see docker-compose.prod.yml
# Load tests: k6 run load-tests/smoke.js
