# Railway production secrets (optional local overrides). Copy railway/env.example to railway/env.local.
#
# The nibras-platform Railway project includes Postgres. Prefer:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   DIRECT_DATABASE_URL=${{Postgres.DATABASE_PUBLIC_URL}}
#
# Redis is required for BullMQ contest sync (worker repeat jobs). Options:
#   Railway Redis — run: ./scripts/railway-provision-redis.sh
#   Or set REDIS_URL manually (Upstash, etc.)
#   Or USE_RAILWAY_REDIS=true to wire ${{Redis.REDIS_URL}} via railway-secrets.sh
REDIS_URL=
USE_RAILWAY_REDIS=true

RAILWAY_API_URL=https://web-production-3011ec.up.railway.app
RAILWAY_API_SERVICE=api
RAILWAY_WEB_SERVICE=web
RAILWAY_WORKER_SERVICE=worker

# Fastify API public URL (used by web gateway upstream)
RAILWAY_FASTIFY_ORIGIN=https://api-production-bd99.up.railway.app
# NestJS legacy backend (internal contests, /api/contests*)
NIBRAS_NESTJS_ORIGIN=https://nibras-backend.up.railway.app

# Set on Railway dashboard or via: ./scripts/railway-secrets.sh
DATABASE_URL=
DIRECT_DATABASE_URL=
NIBRAS_ENCRYPTION_KEY=
AUTH_SECRET=

# Startup contest + problem sync when DB is empty or stale (default: enabled in production)
COMPETITIONS_STARTUP_SYNC=

# Google OAuth (Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client)
# Add authorized JavaScript origins (Web application):
#   https://web-production-3011ec.up.railway.app
#   http://localhost:8080
# Optional legacy redirect URIs if using redirect-based OAuth:
#   https://web-production-3011ec.up.railway.app/Login/loginPage/google-callback.html
